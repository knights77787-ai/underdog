# EC2 + lumen.ai.kr 예시 설정
# 사용: sudo cp Docs/nginx-lumen-ec2.conf.example /etc/nginx/sites-available/lumen.ai.kr
#       sudo ln -s /etc/nginx/sites-available/lumen.ai.kr /etc/nginx/sites-enabled/
#       sudo nginx -t && sudo systemctl reload nginx
#
# SSL 인증서 경로는 Let's Encrypt(certbot) 등으로 발급 후 실제 경로로 수정하세요.

server {
    listen 443 ssl;
    server_name lumen.ai.kr;

    ssl_certificate     /etc/letsencrypt/live/lumen.ai.kr/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/lumen.ai.kr/privkey.pem;

    # WebSocket: 실시간 자막·알림용 (필수)
    location /ws {
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 86400;
        proxy_pass http://127.0.0.1:8000;
    }

    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
