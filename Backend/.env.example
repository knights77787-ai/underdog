#
# Backend 환경변수 템플릿
# - 이 파일(.env.example)은 커밋 OK
# - 실제 키/시크릿은 Backend/.env에 넣고 커밋 금지 (.gitignore에 .env 포함됨)
#

# 로그 레벨: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# (권장) OAuth 성공 후 프론트로 돌아갈 URL
# - 로컬 개발: 아래 그대로 사용
# - 배포 시: https://<your-domain>/live 같은 실제 프론트 주소로 변경
FRONTEND_AUTH_REDIRECT_URL=http://127.0.0.1:8000/live

# ----------------------------
# 관리자 (선택)
# ----------------------------
# /admin/* 보호용 토큰. 요청 헤더에 X-Admin-Token: <ADMIN_TOKEN>
ADMIN_TOKEN=CHANGE_ME_ADMIN_TOKEN

# 개발 모드: 1이면 admin 토큰 없이 /admin/* 접근 허용 (배포 시 0 또는 제거)
# DEV=1

# ----------------------------
# Google OAuth (선택)
# ----------------------------
# Google Cloud Console에서 OAuth Client 생성 후 입력
GOOGLE_CLIENT_ID=CHANGE_ME_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=CHANGE_ME_GOOGLE_CLIENT_SECRET

# Google Cloud Console의 Authorized redirect URI와 정확히 동일해야 함
# 예) http://127.0.0.1:8000/auth/google/callback
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/auth/google/callback

# ----------------------------
# Kakao OAuth (선택)
# ----------------------------
KAKAO_CLIENT_ID=CHANGE_ME_KAKAO_CLIENT_ID

# 선택: 카카오 앱 설정에 따라 필요한 경우만
KAKAO_CLIENT_SECRET=CHANGE_ME_KAKAO_CLIENT_SECRET

# 카카오 개발자 콘솔 Redirect URI와 정확히 동일해야 함
# 예) http://127.0.0.1:8000/auth/kakao/callback
KAKAO_REDIRECT_URI=http://127.0.0.1:8000/auth/kakao/callback
